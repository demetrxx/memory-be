{
  "name": "memory",
  "version": "0.0.1",
  "description": "",
  "author": "demetrxx",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build && pnpm email:templates:copy",
    "format": "prettier --write \"apps/**/*.ts\" \"apps/**/*.tsx\" \"libs/**/*.ts\" \"libs/**/*.tsx\"",
    "start": "nest start",
    "dev": "TZ=UTC nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/mono/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.{ts,tsx}\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/mono/test/jest-e2e.json",
    "email:dev": "HOME=${TMPDIR:-/tmp} email dev --dir libs/email/src/emails --port 3001",
    "email:export": "HOME=${TMPDIR:-/tmp} email export --dir libs/email/src/emails --outDir libs/email/templates --pretty",
    "email:typecheck": "tsc -p libs/email/src/tsconfig.json",
    "email:templates:copy": "node -e \"const fs=require('fs'); const path=require('path'); const src=path.resolve('libs/email/templates'); const dest=path.resolve('dist/libs/email/templates'); if (!fs.existsSync(src)) process.exit(0); fs.mkdirSync(path.dirname(dest), { recursive: true }); fs.rmSync(dest, { recursive: true, force: true }); fs.cpSync(src, dest, { recursive: true });\"",
    "typeorm": "ts-node -P tsconfig.json -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d libs/core/src/db/cli-data-source.ts",
    "db-extensions": "ts-node -P tsconfig.json -r tsconfig-paths/register ./node_modules/typeorm-extension/bin/cli.cjs -d libs/core/src/db/cli-data-source.ts",
    "mig:run": "npm run typeorm migration:run --",
    "mig:revert": "npm run typeorm migration:revert --",
    "seed": "pnpm db-extensions seed:run --",
    "db:drop": "npm run typeorm schema:drop --",
    "mig:gen": "pnpm typeorm migration:generate --pretty ./libs/core/src/db/migrations/$N"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.948.0",
    "@aws-sdk/client-ses": "^3.1077.0",
    "@aws-sdk/s3-presigned-post": "^3.954.0",
    "@aws-sdk/s3-request-presigner": "^3.954.0",
    "@bull-board/api": "^6.20.5",
    "@bull-board/fastify": "^6.20.5",
    "@fastify/cookie": "^10.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.2.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.9",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-fastify": "^11.1.6",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/typeorm": "^11.0.0",
    "@smithy/protocol-http": "^5.3.8",
    "@smithy/signature-v4": "^5.3.8",
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.65.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.1",
    "google-auth-library": "^10.7.0",
    "ioredis": "5.8.2",
    "lib": "^5.1.0",
    "mono": "link:",
    "nanoid": "^5.1.11",
    "pg": "^8.16.3",
    "pgvector": "^0.2.1",
    "reflect-metadata": "^0.1.13",
    "runpod-sdk": "^1.1.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "typeorm": "^0.3.28",
    "typeorm-extension": "^3.7.3",
    "uuid": "^13.0.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@react-email/ui": "6.6.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-email": "6.6.5",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/libs/",
      "<rootDir>/apps/"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/apps/mono/src/$1",
      "^@app/core(|/.*)$": "<rootDir>/libs/core/src/$1"
    }
  }
}
